    {
      "name": "Print Event Ticket",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": {\n    \"event\": {\n      \"name\": \"Concert d'été 2026\",\n      \"date\": \"15 juillet 2026\",\n      \"time\": \"20:00\"\n    },\n    \"venue\": {\n      \"name\": \"Amphithéâtre Central\",\n      \"address\": \"123 Parc Central, NY 10001\"\n    },\n    \"seat\": {\n      \"section\": \"A\",\n      \"row\": \"5\",\n      \"seat\": \"12\",\n      \"gate\": \"Nord\"\n    },\n    \"barcode\": {\n      \"value\": \"EVT00012345\"\n    },\n    \"holder\": {\n      \"name\": \"Jean Dupont\"\n    }\n  },\n  \"paper_width\": 48,\n  \"no_cut\": false,\n  \"feed_lines\": 3\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/print",
          "host": ["{{baseUrl}}"],
          "path": ["api", "print"]
        },
        "description": "Send a ticket to the ZJ-8360 thermal printer over USB.\n\n⚠️ Requires the physical printer to be connected and powered on. Returns 503 if the printer is not found."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// This test will pass when the printer is connected (200)",
              "// and gracefully handle the case where it is not (503)",
              "",
              "if (pm.response.code === 200) {",
              "    pm.test('Status code is 200', function () {",
              "        pm.response.to.have.status(200);",
              "    });",
              "",
              "    pm.test('ok is true', function () {",
              "        pm.expect(pm.response.json().ok).to.eql(true);",
              "    });",
              "",
              "    pm.test('printed 1 ticket', function () {",
              "        const body = pm.response.json();",
              "        pm.expect(body.printed).to.eql(1);",
              "        pm.expect(body.template).to.eql('event');",
              "        pm.expect(body.paper_width).to.eql(48);",
              "    });",
              "} else if (pm.response.code === 503) {",
              "    pm.test('Printer not connected — 503 expected', function () {",
              "        pm.response.to.have.status(503);",
              "        const body = pm.response.json();",
              "        pm.expect(body.ok).to.eql(false);",
              "        pm.expect(body.error).to.be.a('string');",
              "    });",
              "} else {",
              "    pm.test('Unexpected status code: ' + pm.response.code, function () {",
              "        pm.expect.fail('Expected 200 or 503, got ' + pm.response.code);",
              "    });",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
