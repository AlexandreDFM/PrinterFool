{
  "info": {
    "name": "HZTZPrinter API",
    "description": "Complete test collection for the HZTZPrinter Flask API server.\n\nStart the server before running:\n```\npython fool_printer.py serve\n```\n\nDefault base URL: http://localhost:8360/api/\n\nEndpoints covered:\n- GET  /api/health\n- GET  /api/templates\n- POST /api/preview\n- POST /api/print\n- POST /api/qr\n- GET  /api/usb\n- GET  /api/test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "hztz-printer-api-collection"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8360",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        },
        "description": "Liveness probe. Returns 200 as long as the server process is running. Does not require the printer to be connected."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('ok is true', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.ok).to.eql(true);",
              "});",
              "",
              "pm.test('version is 1.0.0', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.version).to.eql('1.0.0');",
              "});",
              "",
              "pm.test('status is ok', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.status).to.eql('ok');",
              "});",
              "",
              "pm.test('printer info is present', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.printer).to.be.an('object');",
              "    pm.expect(body.printer).to.have.property('vendor_id');",
              "    pm.expect(body.printer).to.have.property('product_id');",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
