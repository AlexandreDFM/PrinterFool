# ============================================================
#  HZTZPrinter — Environment Configuration
#  Copy this file to .env and adjust values as needed.
#  Usage: cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# API Server — fool_printer serve
# ------------------------------------------------------------

# Port the HTTP API server will listen on.
# Default: 8360  (matches the ZJ-8360 printer model)
# Usage:   python fool_printer.py serve
#          → http://localhost:8360/api/
HZTZ_PORT=8360

# Enable Flask debug mode (auto-reload + detailed error pages).
# WARNING: never set to true in production.
# Accepted values: true | false
HZTZ_DEBUG=false
